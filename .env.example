# Maritime Vessel Identity Frontend - Environment Variables
# Vite build-time variables - compiled into bundle

# Backend API URL (REQUIRED for frontend to communicate with backend)
# Development: http://localhost:8000
# Production: https://maritime-vessel-api.vercel.app (your backend URL)
VITE_API_URL=http://localhost:8000

# Note: This must be set BEFORE build in Vercel
# Set in Vercel Project Settings → Environment Variables
